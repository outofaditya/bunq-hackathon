# Mission Mode — environment variables
# Copy this to `.env` (cp .env.example .env) and fill in the keys.
# The .env file is gitignored.

# ── Required ──────────────────────────────────────────────────────────────

# bunq sandbox API key. Either:
#   (a) Run `python 01_authentication.py` once — it creates one for you, OR
#   (b) Generate from https://developer.bunq.com → "API key for sandbox"
BUNQ_API_KEY=

# Anthropic — Claude is the brain that drives missions.
# https://console.anthropic.com/  → Settings → API Keys
ANTHROPIC_API_KEY=

# Recommended: claude-haiku-4-5-20251001 (fast + cheap), or claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ElevenLabs — TTS for the agent's voice + Scribe STT for the mic input.
# Both come from the same API key. https://elevenlabs.io/app/settings/api-keys
# WITHOUT THIS, AUDIO IS SILENT in the dashboard.
ELEVENLABS_API_KEY=

# Default narrator voice. Rachel = 21m00Tcm4TlvDq8ikWAM (calm, warm).
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM


# ── Optional ──────────────────────────────────────────────────────────────

# Slack incoming webhook for mission notifications. https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# Google Places API key for live restaurant data. Falls back to a fixture if absent.
GOOGLE_PLACES_API_KEY=

# Public HTTPS URL for the bunq webhook (used in production deploys; ngrok auto-discovered locally).
PUBLIC_BASE_URL=

# Set to 1 in production so logs flush in real time to CloudWatch / equivalent.
PYTHONUNBUFFERED=1
