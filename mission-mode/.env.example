# bunq sandbox — get via `python 01_authentication.py` from hackathon_toolkit
BUNQ_API_KEY=

# Anthropic — claude-haiku-4-5 for the agent loop
ANTHROPIC_API_KEY=

# OpenAI — Whisper STT for voice input
OPENAI_API_KEY=

# ElevenLabs — streaming TTS narration
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Slack incoming webhook — https://api.slack.com/apps → create app → incoming webhooks
SLACK_WEBHOOK_URL=

# Google OAuth desktop-app credentials JSON path (download from console.cloud.google.com)
GOOGLE_CREDENTIALS_JSON=./google_credentials.json
GOOGLE_TOKEN_JSON=./google_token.json
GOOGLE_CALENDAR_INVITEE_EMAIL=

# ngrok public URL pointing at localhost:8000 — set after `ngrok http 8000`
PUBLIC_BASE_URL=

# Sandbox sugardaddy (don't change)
SUGARDADDY_EMAIL=sugardaddy@bunq.com

OPENROUTER_API_KEY=
